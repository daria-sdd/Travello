# ============================================================
# WayAI — переменные окружения
# Скопируйте в .env и заполните значения
# cp .env.example .env
# ============================================================

# ── Anthropic Claude ─────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Firebase ─────────────────────────────────────────────────
# Путь к JSON-ключу Firebase Admin SDK (Service Account)
# Скачать: Firebase Console → Project Settings → Service Accounts → Generate new private key
FIREBASE_CREDENTIALS_PATH=./secrets/firebase.json

# Web API Key из Firebase Console → Project Settings → General
FIREBASE_WEB_API_KEY=AIzaSy...

# ── Amadeus (авиабилеты, отели) ──────────────────────────────
# Зарегистрироваться: https://developers.amadeus.com
AMADEUS_CLIENT_ID=
AMADEUS_CLIENT_SECRET=

# ── Google APIs ──────────────────────────────────────────────
# Places API и Maps JavaScript API
# https://console.cloud.google.com/apis
GOOGLE_PLACES_API_KEY=
GOOGLE_MAPS_API_KEY=

# ── OpenWeather ───────────────────────────────────────────────
# https://openweathermap.org/api
OPENWEATHER_API_KEY=

# ── AWS S3 (для QR и PDF) ────────────────────────────────────
# Используется только если нужно хранить файлы
AWS_REGION=eu-central-1
AWS_S3_BUCKET=wayai-assets
# AWS credentials берутся из ~/.aws/credentials или IRSA

# ── LangSmith (опционально, для трейсинга промптов) ──────────
LANGCHAIN_API_KEY=
LANGCHAIN_TRACING_V2=false

# ── Python AI service URL (для Kotlin backend) ───────────────
AI_SERVICE_URL=http://ai-service:8081
